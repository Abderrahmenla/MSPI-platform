# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://mspi:mspi_dev@localhost:5432/mspi

# ─── Facebook OAuth ──────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:4000/api/v1/auth/facebook/callback

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=change-me-customer-secret
JWT_ADMIN_SECRET=change-me-admin-secret
JWT_CUSTOMER_EXPIRY=24h
JWT_ADMIN_EXPIRY=60m

# ─── App URLs (CORS whitelist) ───────────────────────
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ─── File uploads ────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ─── Rate limiting ───────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Meta Pixel (client-side, in Next.js .env) ──────
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_WHATSAPP_NUMBER=
