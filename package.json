{
  "name": "mspi-platform",
  "version": "0.1.0",
  "private": true,
  "description": "MSPI Fire Safety — ecommerce & quote platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
